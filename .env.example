# Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# Telegram API (https://my.telegram.org/apps dan oling)
API_ID=your_api_id
API_HASH=your_api_hash

# Admin Telegram ID lari (vergul bilan ajrating)
ADMIN_IDS=123456789,987654321

# Majburiy obuna kanali (ixtiyoriy, bo'sh qoldirsa tekshirilmaydi)
REQUIRED_CHANNEL=@your_channel

# Node environment
NODE_ENV=production
